#!/usr/bin/env bash
# Pre-push hook: runs the same checks as CI before allowing push.
# Install: git config core.hooksPath .githooks
set -euo pipefail

# Ensure common tool paths are available (homebrew, nvm, fnm, volta, etc.)
export PATH="/opt/homebrew/bin:/usr/local/bin:$HOME/.nvm/versions/node/$(ls ~/.nvm/versions/node 2>/dev/null | tail -1)/bin:$HOME/.local/bin:$PATH" 2>/dev/null || true

echo "🔍 Running pre-push checks (mirroring CI)..."
echo ""

FAILED=0

# 1. Build
echo "▶ [1/3] TypeScript build..."
if AGENTANYCAST_SKIP_DOWNLOAD=1 npm run build ; then
  echo "✅ Build passed"
else
  echo "❌ Build failed"
  FAILED=1
fi
echo ""

# 2. Tests
echo "▶ [2/3] Vitest..."
if npm test ; then
  echo "✅ Tests passed"
else
  echo "❌ Tests failed"
  FAILED=1
fi
echo ""

# 3. Type check (stricter — noEmit catches more)
echo "▶ [3/3] TypeScript strict check..."
if npx tsc --noEmit ; then
  echo "✅ Type check passed"
else
  echo "❌ Type check failed"
  FAILED=1
fi
echo ""

if [ $FAILED -ne 0 ]; then
  echo "❌ Pre-push checks FAILED. Push aborted."
  echo "   Fix the issues above and try again."
  echo "   To skip (emergency): git push --no-verify"
  exit 1
fi

echo "✅ All pre-push checks passed."
